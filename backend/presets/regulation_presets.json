  "absolute_minimums": {
    "clause_b13_4": {
      "applies_when": "capacity > 3",
      "min_door_width_mm": 750,
      "min_double_leaf_panel_mm": 600,
      "note": "Any exit door of room/storey with capacity>3 shall be >=750mm; double-leaf door each leaf >=600mm; rebated door shall have checking device"
    },
    "clause_b30_3": {
      "applies_when": "door to temporary refuge space",
      "min_clear_width_mm": 850,
      "note": "Take the larger of Table B2 requirement and 850mm; door handle height 950-1050mm"
    }
